op Portal setup","title":"Desktop","titles":["Modules","Module Categories"],"type":"section"},"3":{"category":"","href":"/modules#gaming","subtitle":"","text":" ModuleDescriptiongaming.steamSteam client with dependenciessystem.gpu.amdAMD GPU drivers & configurationsystem.gpu.nvidiaNVIDIA GPU drivers & configuration","title":"Gaming","titles":["Modules","Module Categories"],"type":"section"},"4":{"category":"","href":"/modules#security","subtitle":"","text":" ModuleDescriptionsecrets.agenixEncrypted secrets via agenixsystem.impermanenceEphemeral root with persistent directoriesdesktop.hyprland.theme.caelestiaHyprland Catppuccin theme","title":"Security","titles":["Modules","Module Categories"],"type":"section"},"5":{"category":"","href":"/modules#services","subtitle":"","text":" ModuleDescriptionservices.tailscaleTailscale mesh VPNservices.nginxNginx web serverservices.postgresqlPostgreSQL databaseservices.forgejoForgejo git forgeservices.dockerDocker container runtimeservices.vaultwardenVaultwarden password managerservices.opensshOpenSSH serverservices.cloudflaredCloudflare Tunnelservices.smartdnsSmartDNS proxy","title":"Services","titles":["Modules","Module Categories"],"type":"section"},"6":{"category":"","href":"/modules#dev-tools","subtitle":"","text":" ModuleDescriptioncli-apps.dev-kit.gitGit configurationcli-apps.dev-kit.nixNix configuration & aliasescli-apps.editor.vscodeVS Codecli-apps.editor.jetbrainsJetBrains IDEscli-apps.nix.home-managerhome-manager integrationservices.vscode-serverVS Code remote server","title":"Dev Tools","titles":["Modules","Module Categories"],"type":"section"},"7":{"category":"","href":"/modules#shell--cli","subtitle":"","text":" ModuleDescriptioncli-apps.shell.fishFish shellcli-apps.shell.zshZsh shellcli-apps.tool.ghGitHub CLIcli-apps.file-manager.yaziYazi terminal file manager","title":"Shell & CLI","titles":["Modules","Module Categories"],"type":"section"},"8":{"category":"","href":"/modules#platform","subtitle":"","text":" ModuleDescriptionsystem.wslNixOS-WSL integrationsystem.proxmox.lxcProxmox LXC container supportsystem.boot.lanzabooteSecure Boot with lanzaboote Module list is incomplete — more modules are being added. See the repository for the full list.","title":"Platform","titles":["Modules","Module Categories"],"type":"section"},"9":{"category":"","href":"/#cattery-modules","subtitle":"","text":" Quick-start NixOS configurations. Choose a room, enable it, and get a complete system — theming, gaming, desktop, server, and more. No boilerplate. A curated collection of Nix modules for NixOS, nix-darwin, and home-manager. Built with purr.","title":"cattery-modules","titles":[],"type":"page"},"10":{"category":"","href":"/#quick-start","subtitle":"","text":" # flake.nix\n{\n  inputs.cattery-modules.url = \"https://flakehub.com/f/nixcafe/cattery-modules/*.tar.gz\";\n\n  outputs = { self, nixpkgs, cattery-modules, ... }: {\n    nixosConfigurations.myhost = nixpkgs.lib.nixosSystem {\n      modules = [ cattery-modules.nixosModules.default ];\n    };\n  };\n} # configuration.nix\n{ config, ... }: {\n  cattery.room.desktop.dev.enable = true;\n} One line — full developer desktop with tools, theming, shell, and more.","title":"Quick Start","titles":["cattery-modules"],"type":"section"},"11":{"category":"","href":"/#why-cattery-modules","subtitle":"","text":" Room-based — pre-configured module bundles; enable one and get dozensSensible defaults — every module comes with good defaults, override what you needCross-platform — NixOS, nix-darwin, home-manager, and NixOS-WSLModular — use rooms for quick-start, or enable individual modules piece by pieceExtensible — compose rooms with extra modules from other flakes","title":"Why cattery-modules?","titles":["cattery-modules"],"type":"section"},"12":{"category":"","href":"/quick-start#quick-start","subtitle":"","text":" Add cattery-modules as a flake input: {\n  inputs = {\n    nixpkgs.url = \"github:NixOS/nixpkgs/nixos-unstable\";\n    cattery-modules.url = \"https://flakehub.com/f/nixcafe/cattery-modules/*.tar.gz\";\n  };\n}","title":"Quick Start","titles":[],"type":"page"},"13":{"category":"","href":"/quick-start#installation","subtitle":"","text":" Add cattery-modules as a flake input: {\n  inputs = {\n    nixpkgs.url = \"github:NixOS/nixpkgs/nixos-unstable\";\n    cattery-modules.url = \"https://flakehub.com/f/nixcafe/cattery-modules/*.tar.gz\";\n  };\n}","title":"Installation","titles":["Quick Start"],"type":"section"},"14":{"category":"","href":"/quick-start#enabling-a-room","subtitle":"","text":" Rooms are the fastest way to get started. Add the modules to your system config and enable a room: # configuration.nix\n{ cattery-modules, ... }: {\n  imports = [ cattery-modules.nixosModules.default ];\n\n  cattery.room.desktop.dev.enable = true;\n} That's it. Run nixos-rebuild switch and you'll have a fully configured developer desktop.","title":"Enabling a Room","titles":["Quick Start"],"type":"section"},"15":{"category":"","href":"/quick-start#using-with-home-manager","subtitle":"","text":" Standalone home-manager (no NixOS): # home.nix\n{ cattery-modules, ... }: {\n  imports = [ cattery-modules.homeModules.default ];\n\n  cattery.room.desktop.dev.enable = true;\n}","title":"Using with Home-Manager","titles":["Quick Start"],"type":"section"},"16":{"category":"","href":"/quick-start#using-with-nix-darwin","subtitle":"","text":" macOS users: { cattery-modules, ... }: {\n  imports = [ cattery-modules.darwinModules.default ];\n\n  cattery.room.desktop.dev.enable = true;\n}","title":"Using with nix-darwin","titles":["Quick Start"],"type":"section"},"17":{"category":"","href":"/quick-start#picking-individual-modules","subtitle":"","text":" Don't want a full room? Enable modules one at a time: {\n  cattery = {\n    themes.catppuccin.enable = true;\n    desktop.hyprland.enable = true;\n    services.tailscale.enable = true;\n    cli-apps.dev-kit.git.enable = true;\n  };\n}","title":"Picking Individual Modules","titles":["Quick Start"],"type":"section"},"18":{"category":"","href":"/rooms#rooms","subtitle":"","text":" Rooms are pre-configured module bundles. Enable one room and get dozens of modules with sensible defaults. Each room includes and extends the one below it.","title":"Rooms","titles":[],"type":"page"},"19":{"category":"","href":"/rooms#room-hierarchy","subtitle":"","text":" room.basis\n └─ room.general\n     ├─ room.server-mini\n     │   └─ room.server\n     ├─ room.container\n     └─ room.desktop.basis\n          └─ room.desktop.general\n               ├─ room.desktop.dev\n               ├─ room.desktop.game\n               └─ room.desktop.wsl","title":"Room Hierarchy","titles":["Rooms"],"type":"section"},"20":{"category":"","href":"/rooms#base-rooms","subtitle":"","text":" RoomDescriptionKey Modulesroom.basisEssential system setupnix, git, openssh, locale, fonts, networkroom.generalEveryday additionsshell (fish/zsh), CLI tools, editors, file manager","title":"Base Rooms","titles":["Rooms","Available Rooms"],"type":"section"},"21":{"category":"","href":"/rooms#server-rooms","subtitle":"","text":" RoomDescriptionKey Modulesroom.server-miniLightweight serveropenssh, tailscale, firewallroom.serverFull serverdocker, nginx, postgresql, forgejo, vaultwarden, qemu-guestroom.containerContainer hostincus, distrobox","title":"Server Rooms","titles":["Rooms","Available Rooms"],"type":"section"},"22":{"category":"","href":"/rooms#desktop-rooms","subtitle":"","text":" RoomDescriptionKey Modulesroom.desktop.basisDesktop basedisplay manager, compositor (hyprland/niri/plasma), Catppuccin themingroom.desktop.generalFull desktopaudio (pipewire), input, fonts, apps (browser, mail, etc.)room.desktop.devDeveloper desktopIDEs (vscode/jetbrains), databases, dev-kit, containersroom.desktop.gameGaming desktopSteam, GPU drivers (AMD/NVIDIA), Wine, RetroArchroom.desktop.wslWSL desktopWSL-optimized desktop with GPU integration","title":"Desktop Rooms","titles":["Rooms","Available Rooms"],"type":"section"},"23":{"category":"","href":"/rooms#customizing-rooms","subtitle":"","text":" Rooms use lib.mkDefault for sub-module enables, so you can opt out of any individual module: cattery.room.desktop.game.enable = true;\n# Still get everything except JetBrains\ncattery.cli-apps.editor.jetbrains.enable = false;","title":"Customizing Rooms","titles":["Rooms"],"type":"section"}},"dirtCount":0,"index":[[")room",{"2":{"22":1}}],["(amd",{"2":{"22":1}}],["(vscode",{"2":{"22":1}}],["(browser,",{"2":{"22":1}}],["(pipewire),",{"2":{"22":1}}],["(hyprland",{"2":{"22":1}}],["(fish",{"2":{"20":1}}],["(no",{"2":{"15":1}}],["│",{"2":{"19":1}}],["├─",{"2":{"19":4}}],["└─",{"2":{"19":5}}],["\"github",{"2":{"12":1,"13":1}}],["\"https",{"2":{"10":1,"12":1,"13":1}}],["];",{"2":{"10":1,"14":1,"15":1,"16":1}}],["[",{"2":{"10":1,"14":1,"15":1,"16":1}}],["};",{"2":{"10":2,"12":1,"13":1,"17":1}}],["}",{"2":{"10":4,"12":1,"13":1,"14":2,"15":2,"16":2,"17":1}}],["*",{"2":{"10":1,"12":1,"13":1}}],["=",{"2":{"10":5,"12":3,"13":3,"14":2,"15":2,"16":2,"17":5,"23":2}}],["using",{"3":{"15":1,"16":1}}],["users",{"2":{"16":1}}],["use",{"2":{"11":1,"23":1}}],["unstable\";",{"2":{"12":1,"13":1}}],["under",{"2":{"0":1}}],["url",{"2":{"10":1,"12":2,"13":2}}],["{",{"2":{"10":6,"12":2,"13":2,"14":2,"15":2,"16":2,"17":2}}],["#",{"2":{"10":2,"14":1,"15":1,"23":1}}],["qemu",{"2":{"21":1}}],["quick",{"2":{"9":1,"11":1},"3":{"10":1,"12":1},"4":{"13":1,"14":1,"15":1,"16":1,"17":1}}],["qt,",{"2":{"1":1}}],["—",{"2":{"8":1,"9":1,"10":1,"11":5}}],["base",{"3":{"20":1}}],["basedisplay",{"2":{"22":1}}],["based",{"2":{"11":1}}],["basisdesktop",{"2":{"22":1}}],["basisessential",{"2":{"20":1}}],["basis",{"2":{"19":2,"20":1,"22":1}}],["below",{"2":{"18":1}}],["being",{"2":{"8":1}}],["by",{"2":{"11":1}}],["bundles",{"2":{"18":1}}],["bundles;",{"2":{"11":1}}],["built",{"2":{"9":1}}],["boilerplate",{"2":{"9":1}}],["boot",{"2":{"8":2}}],["brains",{"2":{"6":1,"23":1}}],["yazi",{"2":{"7":2}}],["yaziyazi",{"2":{"7":1}}],["you'll",