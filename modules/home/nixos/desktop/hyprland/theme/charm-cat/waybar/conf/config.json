{
  "layer": "top",
  "position": "top",
  "height": 28,
  "modules-left": [
    "custom/launcher",
    "cpu",
    "memory",
    "network",
    "backlight",
    "pulseaudio"
  ],
  "modules-center": [
    "clock",
    "hyprland/workspaces",
    "idle_inhibitor"
  ],
  "modules-right": [
    "tray",
    "battery",
    "custom/power"
  ],
  "custom/launcher": {
    "format": "\uf313 ",
    "on-click": "anyrun",
    "tooltip": false
  },
  "cpu": {
    "format": "\udb80\udf5b {usage}%",
    "interval": 1
  },
  "memory": {
    "format": "\udb83\udee0 {percentage}%",
    "interval": 1,
    "tooltip-format": "memory: {used:0.1f}G / {total:0.1f}G\nswap: {swapUsed:0.1f}G / {swapTotal:0.1f}G",
    "states": {
      "warning": 80,
      "critical": 90
    }
  },
  "network": {
    "interval": 5,
    "format-wifi": "пЗЂ {essid}",
    "format-ethernet": "пЫњ {ipaddr}/{cidr}",
    "format-linked": "пЫњ {ifname} (No IP)",
    "format-disconnected": "п™© Disconnected",
    "format-disabled": "п™© Disabled",
    "format-alt": "пГШ {bandwidthUpBytes} | пГЧ {bandwidthDownBytes}",
    "tooltip-format": "пФВ {ifname} via {gwaddr}"
  },
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [
      "оОН",
      "оПУ",
      "оПС",
      "оПП",
      "оПО",
      "оПН",
      "оПК",
      "оПИ",
      "оОЫ"
    ]
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "пС¶ Mute",
    "format-bluetooth": "пКУ {volume}% {format_source}",
    "format-bluetooth-muted": "пКУ Mute",
    "format-source": "пД∞ {volume}%",
    "format-source-muted": "пД±",
    "format-icons": {
      "headphone": "пА•",
      "hands-free": "пЯП",
      "headset": "пЯН",
      "phone": "пВХ",
      "portable": "пВХ",
      "car": "пЖє",
      "default": [
        "пА¶",
        "пАІ",
        "пА®"
      ]
    },
    "scroll-step": 5.0,
    "on-click": "wpctl set-mute @DEFAULT_SINK@ toggle",
    "on-click-right": "pavucontrol",
    "smooth-scrolling-threshold": 1
  },
  "clock": {
    "interval": 60,
    "align": 0,
    "rotate": 0,
    "tooltip-format": "<big>{:%B %Y}</big>\n<tt>{calendar}</tt>",
    "format": "пАЧ {:%H:%M}"
  },
  "hyprland/workspaces": {
    "format": "{icon}",
    "persistent-workspaces": {
      "*": 6
    }
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "\uf06e ",
      "deactivated": "\uf070 "
    },
    "tooltip": false
  },
  "tray": {
    "icon-size": 15,
    "spacing": 5
  },
  "battery": {
    "bat": "BAT0",
    "adapter": "ADP0",
    "interval": 60,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "max-length": 20,
    "format": "{icon} {capacity}%",
    "format-warning": "{icon} {capacity}%",
    "format-critical": "{icon} {capacity}%",
    "format-charging": "<span font-family='Font Awesome 6 Free'>пГІ</span> {capacity}%",
    "format-plugged": "пЗ¶ {capacity}%",
    "format-alt": "{icon} {time}",
    "format-full": "пЗ¶ {capacity}%",
    "format-icons": [
      "пЙД ",
      "пЙГ ",
      "пЙВ ",
      "пЙБ ",
      "пЙА "
    ]
  },
  "custom/power": {
    "format": "\uf011 ",
    "on-click": "pidof wlogout || wlogout",
    "tooltip": false
  }
}